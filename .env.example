# Copy this to .env and fill in all values before running docker compose
# NEVER commit .env

# At least 64 random characters — generate with:
# openssl rand -base64 64
JWT_SECRET=replace_with_long_random_secret_min_64_chars

# Single-user credentials for the Torro web UI
APP_USERNAME=admin
# Generate the bcrypt hash with Node.js:
#   node -e "const b=require('bcrypt'); console.log(b.hashSync('yourpassword',12))"
APP_PASSWORD_HASH=replace_with_bcrypt_hash_of_your_password

# qBittorrent internal credentials (not exposed publicly)
QBIT_USERNAME=admin
QBIT_PASSWORD=replace_with_qbittorrent_webui_password

# Production only: set to your domain e.g. https://yourdomain.com
# Leave empty for Docker-internal deployments (traffic comes through Nginx proxy)
ALLOWED_ORIGIN=
